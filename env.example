# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Note: the YouTube Data API key is NOT a frontend variable. It's set as a
# Supabase Edge Function secret instead, so it never reaches the browser:
#   supabase secrets set YOUTUBE_API_KEY=your-youtube-api-key
#   supabase secrets set YOUTUBE_CHANNEL_ID=your-channel-id
